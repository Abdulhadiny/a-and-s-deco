generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ──────────────────────────────────────────

enum TransactionType {
  credit
  debit
}

enum AuditAction {
  create
  update
  delete
  read
}

enum PaymentStatus {
  outstanding
  partial
  reconciled
  cancelled
}

enum ItemStatus {
  AVAILABLE
  DAMAGED
  RETIRED
}

enum EventType {
  WEDDING
  NAMING
  BIRTHDAY
  GRADUATION
  OTHER
}

enum EventStatus {
  UPCOMING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ReturnCondition {
  GOOD
  DAMAGED
  MISSING
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  DECLINED
}

// ─── SYSTEM & AUTH ─────────────────────────────────

model Location {
  id        String   @id @default(cuid())
  name      String
  address   String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  users                 User[]
  inventoryStock        InventoryStock[]
  inventoryTransactions InventoryTransaction[]
  expenses              Expense[]
  events                Event[]

  @@map("locations")
}

model SystemConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Json
  description String?
  updatedBy   String?  @map("updated_by")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  updatedByUser User? @relation(fields: [updatedBy], references: [id])

  @@map("system_configs")
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  displayName String   @map("display_name")
  description String?
  isSystem    Boolean  @default(false) @map("is_system")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  users           User[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String  @id @default(cuid())
  module      String
  action      String
  description String?

  rolePermissions RolePermission[]

  @@unique([module, action])
  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  passwordHash String    @map("password_hash")
  roleId       String?   @map("role_id")
  locationId   String?   @map("location_id")
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  role     Role?     @relation(fields: [roleId], references: [id])
  location Location? @relation(fields: [locationId], references: [id])

  systemConfigs         SystemConfig[]
  inventoryTransactions InventoryTransaction[]
  expenses              Expense[]
  auditLogs             AuditLog[]
  customerPayments      CustomerPayment[]

  @@map("users")
}

// ─── INVENTORY ─────────────────────────────────────

model ItemCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  items Item[]

  @@map("item_categories")
}

model Item {
  id             String     @id @default(cuid())
  categoryId     String     @map("category_id")
  name           String
  tag            String     @unique
  rentalPrice    Decimal    @map("rental_price") @db.Decimal(18, 2)
  description    String?
  imageUrl       String?    @map("image_url")
  status         ItemStatus @default(AVAILABLE)
  conditionNotes String?    @map("condition_notes")
  createdAt      DateTime   @default(now()) @map("created_at")

  category   ItemCategory @relation(fields: [categoryId], references: [id])
  eventItems EventItem[]
  stock      InventoryStock[]
  transactions InventoryTransaction[]

  @@index([categoryId])
  @@index([status])
  @@map("items")
}

model InventoryStore {
  id        String  @id @default(cuid())
  storeCode String  @unique @map("store_code")
  storeName String  @map("store_name")
  isActive  Boolean @default(true) @map("is_active")

  stock        InventoryStock[]
  transactions InventoryTransaction[]

  @@map("inventory_stores")
}

model InventoryStock {
  id         String   @id @default(cuid())
  storeId    String   @map("store_id")
  itemId     String   @map("item_id")
  locationId String   @map("location_id")
  currentQty Int      @default(0) @map("current_qty")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  store    InventoryStore @relation(fields: [storeId], references: [id])
  item     Item           @relation(fields: [itemId], references: [id])
  location Location       @relation(fields: [locationId], references: [id])

  @@unique([storeId, itemId, locationId])
  @@map("inventory_stock")
}

model InventoryTransaction {
  id              String          @id @default(cuid())
  storeId         String          @map("store_id")
  itemId          String          @map("item_id")
  locationId      String          @map("location_id")
  transactionType TransactionType @map("transaction_type")
  quantity        Int
  referenceType   String          @map("reference_type")
  referenceId     String          @map("reference_id")
  notes           String?
  createdAt       DateTime        @default(now()) @map("created_at")
  createdBy       String?         @map("created_by")

  store    InventoryStore @relation(fields: [storeId], references: [id])
  item     Item           @relation(fields: [itemId], references: [id])
  location Location       @relation(fields: [locationId], references: [id])
  creator  User?          @relation(fields: [createdBy], references: [id])

  @@index([storeId])
  @@index([itemId])
  @@index([referenceType, referenceId])
  @@map("inventory_transactions")
}

// ─── OPERATIONS ────────────────────────────────────

model Customer {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  email     String?
  address   String?
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")

  events   Event[]
  payments CustomerPayment[]

  @@map("customers")
}

model Event {
  id         String      @id @default(cuid())
  customerId String      @map("customer_id")
  locationId String?     @map("location_id")
  title      String
  eventType  EventType   @map("event_type")
  eventDate  DateTime    @map("event_date") @db.Date
  setupDate  DateTime?   @map("setup_date") @db.Date
  returnDate DateTime?   @map("return_date") @db.Date
  venue      String?
  status     EventStatus @default(UPCOMING)
  notes      String?
  createdAt  DateTime    @default(now()) @map("created_at")

  customer   Customer    @relation(fields: [customerId], references: [id])
  location   Location?   @relation(fields: [locationId], references: [id])
  eventItems EventItem[]
  quotes     Quote[]

  @@index([customerId])
  @@index([eventDate])
  @@index([status])
  @@map("events")
}

model EventItem {
  id              String           @id @default(cuid())
  eventId         String           @map("event_id")
  itemId          String           @map("item_id")
  quantity        Int              @default(1)
  allocatedAt     DateTime         @default(now()) @map("allocated_at")
  returnedAt      DateTime?        @map("returned_at")
  returnCondition ReturnCondition? @map("return_condition")
  damageNotes     String?          @map("damage_notes")
  damagePhotoUrl  String?          @map("damage_photo_url")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  item  Item  @relation(fields: [itemId], references: [id])

  @@unique([eventId, itemId])
  @@index([itemId])
  @@map("event_items")
}

model Quote {
  id            String        @id @default(cuid())
  eventId       String        @map("event_id")
  status        QuoteStatus   @default(DRAFT)
  subtotal      Decimal       @map("subtotal") @db.Decimal(18, 2)
  discount      Decimal?      @db.Decimal(18, 2)
  tax           Decimal?      @db.Decimal(18, 2)
  total         Decimal       @db.Decimal(18, 2)
  amountPaid    Decimal       @default(0) @map("amount_paid") @db.Decimal(18, 2)
  paymentStatus PaymentStatus @default(outstanding) @map("payment_status")
  notes         String?
  createdAt     DateTime      @default(now()) @map("created_at")

  event Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  lines QuoteLine[]

  @@index([eventId])
  @@map("quotes")
}

model QuoteLine {
  id          String  @id @default(cuid())
  quoteId     String  @map("quote_id")
  description String
  quantity    Int     @default(1)
  unitPrice   Decimal @map("unit_price") @db.Decimal(18, 2)
  lineTotal   Decimal @map("line_total") @db.Decimal(18, 2)

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
  @@map("quote_lines")
}

// ─── FINANCE ───────────────────────────────────────

model ExpenseCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  expenses Expense[]

  @@map("expense_categories")
}

model Expense {
  id          String   @id @default(cuid())
  categoryId  String   @map("category_id")
  amount      Decimal  @db.Decimal(18, 2)
  description String?
  expenseDate DateTime @map("expense_date") @db.Date
  locationId  String?  @map("location_id")
  createdAt   DateTime @default(now()) @map("created_at")
  createdBy   String?  @map("created_by")

  category ExpenseCategory @relation(fields: [categoryId], references: [id])
  location Location?       @relation(fields: [locationId], references: [id])
  creator  User?           @relation(fields: [createdBy], references: [id])

  @@index([categoryId])
  @@index([expenseDate])
  @@map("expenses")
}

model CustomerPayment {
  id            String   @id @default(cuid())
  customerId    String   @map("customer_id")
  amount        Decimal  @db.Decimal(18, 2)
  paymentDate   DateTime @map("payment_date") @db.Date
  paymentMethod String?  @map("payment_method")
  reference     String?
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at")
  createdBy     String?  @map("created_by")

  customer Customer @relation(fields: [customerId], references: [id])
  creator  User?    @relation(fields: [createdBy], references: [id])

  @@index([customerId])
  @@map("customer_payments")
}

// ─── AUDIT ─────────────────────────────────────────

model AuditLog {
  id          String      @id @default(cuid())
  userId      String?     @map("user_id")
  action      AuditAction
  module      String
  recordId    String      @map("record_id")
  recordTable String      @map("record_table")
  oldValues   Json?       @map("old_values")
  newValues   Json?       @map("new_values")
  ipAddress   String?     @map("ip_address")
  createdAt   DateTime    @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@index([module])
  @@index([userId])
  @@index([createdAt])
  @@index([recordTable, recordId])
  @@map("audit_logs")
}
